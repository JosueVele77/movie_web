<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>movie_web</display-name>

    <error-page>
        <error-code>404</error-code>
        <location>/pages/error404.jsp</location>
    </error-page>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>io.github.josuevele77.movie_web.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>io.github.josuevele77.movie_web.controller.RegistroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/RegistroServlet</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>ReactivarProductoServlet</servlet-name>
        <servlet-class>io.github.josuevele77.movie_web.controller.ReactivarProductoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReactivarProductoServlet</servlet-name>
        <url-pattern>/ReactivarProductoServlet</url-pattern>
    </servlet-mapping>

</web-app>